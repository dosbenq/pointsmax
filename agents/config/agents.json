{
  "default_timeout_ms": 900000,
  "agents": {
    "claude": {
      "enabled": true,
      "shell": "cat {{prompt_file}} | claude",
      "timeout_ms": 900000
    },
    "gemini": {
      "enabled": true,
      "shell": "cat {{prompt_file}} | gemini",
      "timeout_ms": 900000
    },
    "kimi": {
      "enabled": true,
      "shell": "cat {{prompt_file}} | kimi",
      "timeout_ms": 900000
    },
    "codex": {
      "enabled": true,
      "shell": "codex run \"$(cat {{prompt_file}})\"",
      "timeout_ms": 900000
    }
  }
}
