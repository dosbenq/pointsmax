{
  "default_timeout_ms": 900000,
  "agents": {
    "claude": {
      "enabled": false,
      "shell": "claude -p \"$(cat {{prompt_file}})\"",
      "timeout_ms": 900000
    },
    "gemini": {
      "enabled": true,
      "shell": "gemini -p \"$(cat {{prompt_file}})\"",
      "timeout_ms": 900000
    },
    "kimi": {
      "enabled": false,
      "shell": "kimi -p \"$(cat {{prompt_file}})\"",
      "timeout_ms": 900000
    },
    "codex": {
      "enabled": false,
      "shell": "codex run \"$(cat {{prompt_file}})\"",
      "timeout_ms": 900000
    }
  }
}
