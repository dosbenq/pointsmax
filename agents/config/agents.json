{
  "default_timeout_ms": 900000,
  "default_no_output_timeout_ms": 180000,
  "agents": {
    "claude": {
      "enabled": true,
      "shell": "claude -p \"$(cat {{prompt_file}})\"",
      "timeout_ms": 900000
    },
    "gemini": {
      "enabled": true,
      "shell": "gemini --approval-mode yolo -p \"$(cat {{prompt_file}})\"",
      "timeout_ms": 900000,
      "no_output_timeout_ms": 180000
    },
    "kimi": {
      "enabled": true,
      "shell": "kimi --yolo -p \"$(cat {{prompt_file}})\"",
      "timeout_ms": 1200000,
      "no_output_timeout_ms": 900000
    },
    "codex": {
      "enabled": true,
      "shell": "codex run \"$(cat {{prompt_file}})\"",
      "timeout_ms": 900000
    }
  }
}
