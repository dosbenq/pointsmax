# ── Supabase ──────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # never expose publicly
# Optional: direct Postgres URL used by automation scripts (supabase:verify/sync)
# Format: postgres://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
SUPABASE_DB_URL=
# Optional pooled Supabase API URL for serverless query clients (advanced setups)
# Only used when this is an https:// URL.
SUPABASE_DB_URL_POOLED=

# ── Anthropic ─────────────────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=
# Optional model override (comma-separated fallback order)
# GEMINI_MODEL_CANDIDATES=gemini-2.0-flash,gemini-2.0-flash-lite,gemini-1.5-flash
# Optional safe mode for local testing (disables external Gemini calls)
# DISABLE_GEMINI=1
# Optional default YouTube channel for knowledge ingest admin action
# YOUTUBE_KNOWLEDGE_CHANNEL_URL=https://www.youtube.com/@GreatIndianMiles
# Optional cap for each ingest run (default 15, max 40)
# YOUTUBE_KNOWLEDGE_MAX_VIDEOS=15
# Optional bypass for local test tooling only
# BYPASS_PREMIUM_AI_GATE=1

# ── Inngest (agent workflows) ────────────────────────────────
# INNGEST_EVENT_KEY is used by server routes that emit workflow events.
# INNGEST_SIGNING_KEY is used to verify calls to /api/inngest.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Resend (email alerts) ─────────────────────────────────────
# Get from: https://resend.com/
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=alerts@yourdomain.com

# ── Stripe (premium tier) ─────────────────────────────────────
# Get from: https://dashboard.stripe.com/
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Optional: use a pre-created recurring Stripe Price ID instead of inline price_data
STRIPE_PRO_PRICE_ID=

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Comma-separated CORS allowlist for external clients (origins only, no paths)
# Example: https://pointsmax.com,https://app.pointsmax.com
CORS_ALLOWED_ORIGINS=
CRON_SECRET=some-random-secret-for-protecting-cron-routes

# ── Distributed Rate Limiting (recommended for production) ─────
# Get from Upstash REST API settings
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional: allow stub award data when SEATS_AERO_API_KEY is missing.
# Defaults to disabled in production.
# ALLOW_STUB_AWARD_SEARCH=1

# ── Monitoring / Error Tracking ────────────────────────────────
SENTRY_DSN=                    # From Sentry project settings → Client Keys → DSN
NEXT_PUBLIC_SENTRY_DSN=        # Same value as SENTRY_DSN (used client-side)
SENTRY_ORG=                    # Your Sentry org slug (for source map uploads at build time)
SENTRY_PROJECT=                # Your Sentry project slug
SENTRY_AUTH_TOKEN=             # From Sentry → Settings → Auth Tokens (for CI source map uploads)
HEALTHCHECK_SECRET=

# ── Product Analytics (PostHog) ────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Admin dashboard ───────────────────────────────────────────
# Server-side check (never exposed to browser)
ADMIN_EMAIL=your@email.com
# Client-side check (controls sidebar visibility — not a secret)
NEXT_PUBLIC_ADMIN_EMAIL=your@email.com
